# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,mopd.gov.et,www.mopd.gov.et
SITE_URL=https://mopd.gov.et

# Database (optional — defaults to SQLite)
# DB_ENGINE=postgresql
# DB_NAME=mopd
# DB_USER=mopd
# DB_PASSWORD=
# DB_HOST=127.0.0.1
# DB_PORT=5432

# Email
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=noreply@mopd.gov.et
CONTACT_FORM_NOTIFY_EMAIL=info@mopd.gov.et
