# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,mopd.gov.et,www.mopd.gov.et
SITE_URL=https://mopd.gov.et

# Telegram news notifications (bot must be added to the group)
TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_ID=-5320625965
# For LAN access from other PCs, set SITE_URL to this machine's IP, e.g.:
# SITE_URL=http://10.0.91.102:8002
# Run server with: python manage.py runserver 0.0.0.0:8002
# Optional personal/channel ID — DMs require the user to /start the bot first
# TELEGRAM_CHAT_ID=

# Database (optional — defaults to SQLite)
# DB_ENGINE=postgresql
# DB_NAME=mopd
# DB_USER=mopd
# DB_PASSWORD=
# DB_HOST=127.0.0.1
# DB_PORT=5432

# Email
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=noreply@mopd.gov.et
CONTACT_FORM_NOTIFY_EMAIL=info@mopd.gov.et
